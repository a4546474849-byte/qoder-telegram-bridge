# Qoder CLI — Telegram Bridge
# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram User IDs (comma separated)
ALLOWED_USERS=382401183

# Qoder CLI executable path
QODER_CLI=C:\Qoder_CLI\v0148\qodercli.exe

# Qoder working directory (where sessions/memory stored)
QODER_HOME=C:\Users\Administrator

# Max response time in seconds before Telegram timeout
MAX_TIMEOUT=300

# YOLO mode (auto-execute commands without confirmation)
YOLO=true

# Voice transcription (Groq Whisper API — free tier available)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHISPER_MODEL=small
WHISPER_FALLBACK_API=true
